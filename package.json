{
  "name": "@dojocoding/whatsapp-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @dojocoding/whatsapp-sdk and @dojocoding/whatsapp-mcp.",
  "license": "MIT",
  "author": "Dojo Coding LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DojoCodingLabs/whatsapp-adapter.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "build": "pnpm -r build",
    "size": "pnpm -r size",
    "openspec:validate": "openspec validate --changes --strict || openspec validate --specs --strict || true",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.18",
    "eslint": "^10.4.0",
    "eslint-plugin-import": "^2.32.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.1.9"
  }
}
