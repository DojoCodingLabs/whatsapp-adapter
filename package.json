{
  "name": "@dojocoding/whatsapp",
  "version": "0.2.0",
  "description": "Typed TypeScript SDK for Meta's WhatsApp Cloud API, opinionated for agentic use cases (LLM orchestrators, multi-turn bots, multi-tenant deployments, transactional pipelines).",
  "license": "MIT",
  "author": "Dojo Coding LLC",
  "homepage": "https://github.com/DojoCodingLabs/whatsapp-adapter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DojoCodingLabs/whatsapp-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/DojoCodingLabs/whatsapp-adapter/issues"
  },
  "keywords": [
    "whatsapp",
    "whatsapp-cloud-api",
    "meta",
    "graph-api",
    "typescript",
    "sdk",
    "agent",
    "llm",
    "mcp",
    "webhooks",
    "multi-tenant",
    "opentelemetry"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/adapters/express/index.d.ts",
      "import": "./dist/adapters/express/index.js",
      "require": "./dist/adapters/express/index.cjs"
    },
    "./web": {
      "types": "./dist/adapters/web/index.d.ts",
      "import": "./dist/adapters/web/index.js",
      "require": "./dist/adapters/web/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "openspec:validate": "openspec validate --changes --strict || openspec validate --specs --strict || true",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "express": "^4.17.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.18",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "express": "^4.22.1",
    "fast-check": "^3.23.2",
    "lint-staged": "^15.5.2",
    "msw": "^2.14.5",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
